rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Admin: custom claim (admin==true) YOKI users/{uid} hujjatida role=='admin'.
    // Shu bilan admin panelidan boshqa foydalanuvchilarga admin roli tayinlash ishlaydi.
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.admin == true ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    // Foydalanuvchi shu farzand ID sini o'z hujjatiga qo'shganmi (kabinet egaligi).
    function ownsChild(sid) {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('childIds', []).hasAny([sid]);
    }

    // Ommaviy ko'rinadigan ma'lumotlar: hamma o'qiydi, faqat admin yozadi.
    match /students/{id}              { allow read: if true; allow write: if isAdmin(); }
    match /teachers/{id}              { allow read: if true; allow write: if isAdmin(); }
    match /news/{id}                  { allow read: if true; allow write: if isAdmin(); }
    match /achievements_school/{id}   { allow read: if true; allow write: if isAdmin(); }
    match /achievements_students/{id} { allow read: if true; allow write: if isAdmin(); }
    match /settings/{id}              { allow read: if true; allow write: if isAdmin(); }

    // Elektron kundalik — MAXFIY. Baho va davomat voyaga yetmagan o'quvchining shaxsiy
    // ma'lumoti: faqat admin YOKI shu farzandni kabinetiga qo'shgan ota-ona o'qiydi.
    match /attendance/{id} { allow read: if isAdmin() || ownsChild(resource.data.get('studentId','')); allow write: if isAdmin(); }
    match /grades/{id}     { allow read: if isAdmin() || ownsChild(resource.data.get('studentId','')); allow write: if isAdmin(); }
    // Dars jadvali va uy vazifalari — sinf bo'yicha (shaxsiy PII emas): tizimga kirganlar o'qiydi.
    match /timetable/{id}  { allow read: if request.auth != null; allow write: if isAdmin(); }
    match /homework/{id}   { allow read: if request.auth != null; allow write: if isAdmin(); }

    // Qo'shimcha kontent: galereya, fikrlar, narxlar, qabul bosqichlari, FAQ, tadbirlar.
    match /gallery/{id}               { allow read: if true; allow write: if isAdmin(); }
    match /testimonials/{id}          { allow read: if true; allow write: if isAdmin(); }
    match /plans/{id}                 { allow read: if true; allow write: if isAdmin(); }
    match /admission_steps/{id}       { allow read: if true; allow write: if isAdmin(); }
    match /faq/{id}                   { allow read: if true; allow write: if isAdmin(); }
    match /events/{id}                { allow read: if true; allow write: if isAdmin(); }

    // Arizalar: istalgan foydalanuvchi yuboradi (create), faqat admin o'qiydi/o'chiradi.
    // Hujjat shakli va o'lchamlari cheklangan — spam va katta axlat hujjatlarning oldini oladi.
    match /enrollments/{id} {
      allow create: if request.resource.data.name is string
                    && request.resource.data.name.size() > 0
                    && request.resource.data.name.size() < 200
                    && request.resource.data.keys().hasOnly(['name','phone','grade','direction','lang','ts','created'])
                    && (!('phone' in request.resource.data) || (request.resource.data.phone is string && request.resource.data.phone.size() < 40))
                    && (!('grade' in request.resource.data) || (request.resource.data.grade is string && request.resource.data.grade.size() < 40))
                    && (!('direction' in request.resource.data) || (request.resource.data.direction is string && request.resource.data.direction.size() < 100))
                    && (!('lang' in request.resource.data) || (request.resource.data.lang is string && request.resource.data.lang.size() < 4))
                    && (!('ts' in request.resource.data) || (request.resource.data.ts is string && request.resource.data.ts.size() < 40));
      allow read, update, delete: if isAdmin();
    }

    // Foydalanuvchilar: Gmail bilan kirib o'z rolini tanlaydi; rolni faqat admin o'zgartiradi.
    match /users/{uid} {
      allow read:   if request.auth != null && (request.auth.uid == uid || isAdmin());
      // O'zi faqat ota-ona yoki o'quvchi rolini tanlaydi. O'qituvchi/kurator/zavuch
      // kabi rollarни faqat admin tayinlaydi (quyidagi update qoidаsи isAdmin orqali).
      allow create: if request.auth != null && request.auth.uid == uid
                    && request.resource.data.role in ['parent','student']
                    && request.resource.data.verified == false;
      // Egasi o'z hujjatini yangilay oladi (masalan farzandi ID sini), lekin
      // rol va tasdiqlangan holatini o'zgartira olmaydi — ularni faqat admin.
      allow update: if isAdmin() ||
                    (request.auth != null && request.auth.uid == uid
                     && request.resource.data.role == resource.data.role
                     && request.resource.data.verified == resource.data.verified);
      allow delete: if isAdmin();
    }

    // Qolgan hamma narsa taqiqlangan.
    match /{document=**} { allow read, write: if false; }
  }
}
