rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Admin: custom claim (admin==true) YOKI users/{uid} hujjatida role=='admin'.
    // Shu bilan admin panelidan boshqa foydalanuvchilarga admin roli tayinlash ishlaydi.
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.admin == true ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    // Foydalanuvchi shu farzand ID sini o'z hujjatiga qo'shganmi (kabinet egaligi).
    function ownsChild(sid) {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('childIds', []).hasAny([sid]);
    }

    // Kurator/sinf rahbari: users hujjatida role=='kurator' va shu sinf (classKey)
    // uning assignedClasses ro'yxatida bo'lса — o'sha sinf davomatini yozadi/o'qiydi.
    function isKuratorFor(ck) {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role','') == 'kurator'
        && (ck in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('assignedClasses', []));
    }

    // Fan o'qituvchisi: role=='teacher' va shu sinf uning assignedClasses'ida.
    function isTeacherForClass(ck) {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role','') == 'teacher'
        && (ck in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('assignedClasses', []));
    }
    // O'qituvchiga biriktirilgan fanlar (u faqat shu fan(lar) bahosini yozadi).
    function teacherSubjects() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('assignedSubjects', [])
        : [];
    }
    // Sinf rahbari (davomat): homeroomClasses ro'yxatiga admin biriktirgan sinflar.
    // Rol muhim emas — boshlang'ich sinfda (1-4) sinf rahbari o'qituvchi bo'ladi,
    // 5-11 da kurator bo'ladi. homeroomClasses'ni faqat admin o'rnatadi (self-update
    // qoidasi buni himoya qiladi), shuning uchun bu ro'yxatda bo'lish — davomat huquqi.
    function isHomeroomFor(ck) {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && (ck in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('homeroomClasses', []));
    }
    // O'quv ishlari bo'yicha (O'IBDO' / zavuch) — monitoring baholarini tasdiqlaydi.
    function isZavuch() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role','') == 'zavuch';
    }
    // Monitoring hujjati o'qituvchining o'z sinfi va o'z fanigami?
    function isTeacherOwnDoc(d) {
      return isTeacherForClass(d.get('classKey','')) && (d.get('subject','') in teacherSubjects());
    }

    // Ommaviy ko'rinadigan ma'lumotlar: hamma o'qiydi, faqat admin yozadi.
    match /students/{id}              { allow read: if true; allow write: if isAdmin(); }
    match /teachers/{id}              { allow read: if true; allow write: if isAdmin(); }
    match /news/{id}                  { allow read: if true; allow write: if isAdmin(); }
    match /achievements_school/{id}   { allow read: if true; allow write: if isAdmin(); }
    match /achievements_students/{id} { allow read: if true; allow write: if isAdmin(); }
    match /settings/{id}              { allow read: if true; allow write: if isAdmin(); }

    // Elektron kundalik — MAXFIY. Baho va davomat voyaga yetmagan o'quvchining shaxsiy
    // ma'lumoti: faqat admin YOKI shu farzandni kabinetiga qo'shgan ota-ona o'qiydi.
    match /attendance/{id} {
      allow read:  if isAdmin() || ownsChild(resource.data.get('studentId',''))
                   || isKuratorFor(resource.data.get('classKey','')) || isHomeroomFor(resource.data.get('classKey',''));
      allow write: if isAdmin() || isKuratorFor(request.resource.data.get('classKey','')) || isHomeroomFor(request.resource.data.get('classKey',''));
    }
    // Baholar: admin YOKI shu farzand ota-onasi o'qiydi; o'z sinfidagi o'qituvchi ham o'qiydi.
    // Yozishда o'qituvchi FAQAT o'z fani (subjects mapidagi kalitlar) bahosini o'zgartira oladi.
    match /grades/{id} {
      allow read:   if isAdmin() || ownsChild(resource.data.get('studentId','')) || isTeacherForClass(resource.data.get('classKey',''));
      allow create: if isAdmin() || (isTeacherForClass(request.resource.data.get('classKey',''))
                       && request.resource.data.get('subjects', {}).keys().hasOnly(teacherSubjects()));
      allow update: if isAdmin() || (isTeacherForClass(request.resource.data.get('classKey',''))
                       && request.resource.data.get('subjects', {}).diff(resource.data.get('subjects', {})).affectedKeys().hasOnly(teacherSubjects()));
    }
    // Dars jadvali va uy vazifalari — sinf bo'yicha (shaxsiy PII emas): tizimga kirganlar o'qiydi.
    match /timetable/{id}  { allow read: if request.auth != null; allow write: if isAdmin(); }
    match /homework/{id}   { allow read: if request.auth != null; allow write: if isAdmin(); }

    // Monitoring baholari — fan o'qituvchisi kiritadi (status='pending'), zavuch
    // (O'IBDO') tasdiqlaydi (status='approved'). O'qituvchi tasdiqlangan bahoni
    // o'zgartira olmaydi va o'zi tasdiqlay olmaydi.
    match /monitoring/{id} {
      allow read:   if isAdmin() || isZavuch()
                    || ownsChild(resource.data.get('studentId',''))
                    || isTeacherForClass(resource.data.get('classKey',''));
      allow create: if isAdmin() || isZavuch()
                    || (isTeacherOwnDoc(request.resource.data) && request.resource.data.get('status','') == 'pending');
      allow update: if isAdmin() || isZavuch()
                    || (isTeacherOwnDoc(request.resource.data)
                        && resource.data.get('status','') == 'pending'
                        && request.resource.data.get('status','') == 'pending');
      allow delete: if isAdmin() || isZavuch();
    }

    // Sinflar ro'yxati (admin qo'lда yaratadi — o'quvchi bo'lmasa ham sinf ko'rinadi).
    // Hamma o'qiydi (dropdown'lar uchun kerak), faqat admin yozadi.
    match /classes/{id}               { allow read: if true; allow write: if isAdmin(); }

    // Qo'shimcha kontent: galereya, fikrlar, narxlar, qabul bosqichlari, FAQ, tadbirlar.
    match /gallery/{id}               { allow read: if true; allow write: if isAdmin(); }
    match /testimonials/{id}          { allow read: if true; allow write: if isAdmin(); }
    match /plans/{id}                 { allow read: if true; allow write: if isAdmin(); }
    match /admission_steps/{id}       { allow read: if true; allow write: if isAdmin(); }
    match /faq/{id}                   { allow read: if true; allow write: if isAdmin(); }
    match /events/{id}                { allow read: if true; allow write: if isAdmin(); }

    // Arizalar: istalgan foydalanuvchi yuboradi (create), faqat admin o'qiydi/o'chiradi.
    // Hujjat shakli va o'lchamlari cheklangan — spam va katta axlat hujjatlarning oldini oladi.
    match /enrollments/{id} {
      allow create: if request.resource.data.name is string
                    && request.resource.data.name.size() > 0
                    && request.resource.data.name.size() < 200
                    && request.resource.data.keys().hasOnly(['name','phone','grade','direction','lang','ts','created'])
                    && (!('phone' in request.resource.data) || (request.resource.data.phone is string && request.resource.data.phone.size() < 40))
                    && (!('grade' in request.resource.data) || (request.resource.data.grade is string && request.resource.data.grade.size() < 40))
                    && (!('direction' in request.resource.data) || (request.resource.data.direction is string && request.resource.data.direction.size() < 100))
                    && (!('lang' in request.resource.data) || (request.resource.data.lang is string && request.resource.data.lang.size() < 4))
                    && (!('ts' in request.resource.data) || (request.resource.data.ts is string && request.resource.data.ts.size() < 40));
      allow read, update, delete: if isAdmin();
    }

    // Foydalanuvchilar: Gmail bilan kirib o'z rolini tanlaydi; rolni faqat admin o'zgartiradi.
    match /users/{uid} {
      allow read:   if request.auth != null && (request.auth.uid == uid || isAdmin());
      // O'zi faqat ota-ona yoki o'quvchi rolini tanlaydi. O'qituvchi/kurator/zavuch
      // kabi rollarни faqat admin tayinlaydi (quyidagi update qoidаsи isAdmin orqali).
      allow create: if request.auth != null && request.auth.uid == uid
                    && request.resource.data.role in ['parent','student']
                    && request.resource.data.verified == false;
      // Egasi o'z hujjatini yangilay oladi (masalan farzandi ID sini), lekin rol,
      // tasdiqlangan holat va biriktirilgan sinflarni o'zgartira olmaydi — faqat admin.
      allow update: if isAdmin() ||
                    (request.auth != null && request.auth.uid == uid
                     && request.resource.data.role == resource.data.role
                     && request.resource.data.verified == resource.data.verified
                     && request.resource.data.get('assignedClasses', []) == resource.data.get('assignedClasses', [])
                     && request.resource.data.get('assignedSubjects', []) == resource.data.get('assignedSubjects', [])
                     && request.resource.data.get('homeroomClasses', []) == resource.data.get('homeroomClasses', []));
      allow delete: if isAdmin();
    }

    // Qolgan hamma narsa taqiqlangan.
    match /{document=**} { allow read, write: if false; }
  }
}
